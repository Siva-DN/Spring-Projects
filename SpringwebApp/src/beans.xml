<?xml version="1.0" encoding="UTF-8"?>
<beans 
     xmlns="https://www.springframework.org/schema/beans"
     xmlns:xsi="https://www.w3.org/2001/XMLSchema-instance"
     xsi:schemaLocation="
       https://www.springframework.org/schema/beans
       https://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="b1" class="Spring1.Bike">
        <property name="bike_Name" value="Royal_Enfield"/>
        <property name="bike_Model" value="bf7"/>
        <property name="bike_Price" value="2000000"/>
        <property name="bike_Color" value="black"/>
    </bean>

</beans>